generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ───────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(cuid())
  token      String   @unique
  identifier String
  expires    DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
}

// ─── User ──────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  credits          Int       @default(0)
  permanentCredits Int       @default(0)
  stripeCustomerId String?   @unique
  extraInfo        Json?

  accounts       Account[]
  sessions       Session[]
  stripeCustomer StripeCustomer?
  creditHistory  UserCreditHistory[]
  sites          Site[]

  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Stripe Models ─────────────────────────────────────────────

model StripeCustomer {
  id            String              @id // Stripe customer ID
  user          User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String?             @unique
  email         String?
  name          String?
  metadata      Json?
  subscriptions StripeSubscription[]
  charges       StripeCharge[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("stripe_customers")
}

model StripeProduct {
  id          String        @id // Stripe product ID
  name        String
  description String?
  active      Boolean       @default(true)
  metadata    Json?
  prices      StripePrice[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("stripe_products")
}

model StripePrice {
  id            String              @id // Stripe price ID
  product       StripeProduct?      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId     String?
  active        Boolean             @default(true)
  currency      String
  unitAmount    Int // Amount in cents
  type          String // one_time or recurring
  interval      String? // month, year
  intervalCount Int?
  metadata      Json?
  subscriptions StripeSubscription[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("stripe_prices")
}

model StripeSubscription {
  id                 String         @id // Stripe subscription ID
  customer           StripeCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId         String
  price              StripePrice    @relation(fields: [priceId], references: [id], onDelete: Cascade)
  priceId            String
  status             String // active, past_due, canceled, etc.
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  canceledAt         DateTime?
  metadata           Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([customerId])
  @@index([status])
  @@map("stripe_subscriptions")
}

model StripeCharge {
  id            String         @id // Stripe charge ID
  customer      StripeCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId    String
  amount        Int // Amount in cents
  currency      String
  status        String // succeeded, pending, failed
  description   String?
  metadata      Json?
  paymentMethod String?
  refunded      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("stripe_charges")
}

model StripeProcessedEvent {
  id        String   @id // Stripe event ID (evt_xxx)
  type      String // Event type (e.g., "checkout.session.completed")
  createdAt DateTime @default(now())

  @@map("stripe_processed_events")
}

// ─── Credits ───────────────────────────────────────────────────

enum CreditReason {
  PURCHASE
  SUBSCRIPTION_CREATE
  SUBSCRIPTION_RENEWAL
  SUBSCRIPTION_UPDATE
  CAMPAIGN_USAGE
  REGISTRATION_BONUS
  PROMOTION
  OTHER
}

model UserCreditHistory {
  id              String       @id @default(cuid())
  user            User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId          String?
  credits         Int // Amount added/removed
  previousCredits Int
  newCredits      Int
  reason          CreditReason @default(OTHER)
  reasonExtra     String?      @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([userId])
}

model ProviderCredential {
  id       String @id @default(cuid())
  provider String
  key      String
  value    String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, key])
  @@index([provider])
}

// ─── Discovery Pipeline ──────────────────────────────────────

enum Platform {
  REDDIT
  YOUTUBE
}

enum OpportunityStatus {
  DISCOVERED
  GENERATING
  PENDING_REVIEW
  APPROVED
  POSTING
  POSTED
  SKIPPED
  FAILED
}

enum CommentStatus {
  DRAFT
  APPROVED
  POSTED
  FAILED
  SKIPPED
}

enum DiscoveryRunStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum SiteMode {
  MANUAL
  AUTO
}

model Site {
  id          String     @id @default(cuid())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  url         String
  name        String
  description String     @db.Text
  valueProps     String[]
  keywords       String[]
  keywordConfig    Json?      // Structured: { features, competitors, brand, reddit, youtube }
  discoveryConfig  Json?      // Discovery filter thresholds (minRedditUpvotes, minRedditComments, etc.)
  brandTone        String
  mode           SiteMode   @default(MANUAL)
  dailyAutoLimit Int        @default(20)
  platforms      Platform[]
  active      Boolean    @default(true)

  discoveryRuns DiscoveryRun[]
  opportunities Opportunity[]
  comments      Comment[]

  // HV Discovery Pipeline
  hvDiscoveryRuns  HVDiscoveryRun[]
  hvQueries        HVQuery[]
  hvOpportunities  HVOpportunity[]
  hvComments       HVComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, active])
}

model DiscoveryRun {
  id             String             @id @default(cuid())
  site           Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId         String
  platform       Platform
  status         DiscoveryRunStatus
  keywordsUsed   String[]
  foundCount     Int                @default(0)
  scoredCount    Int                @default(0)
  generatedCount Int                @default(0)
  postedCount    Int                @default(0)
  errorMessage   String?            @db.Text
  startedAt      DateTime           @default(now())
  completedAt    DateTime?

  opportunities Opportunity[]

  @@index([siteId])
  @@index([siteId, platform, startedAt])
}

model Opportunity {
  id             String            @id @default(cuid())
  site           Site              @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId         String
  discoveryRun   DiscoveryRun      @relation(fields: [discoveryRunId], references: [id], onDelete: Cascade)
  discoveryRunId String
  platform       Platform
  status         OpportunityStatus @default(DISCOVERED)

  // Content
  externalId     String
  contentUrl     String
  title          String
  body           String?  @db.Text
  sourceContext  String // subreddit or channel name
  author         String?
  viewCount      Int?
  commentCount   Int?
  publishedAt    DateTime?
  matchedKeyword String
  metadata       Json?

  // Scoring
  relevanceScore       Float
  postType             String
  scoreReason          String? @db.Text
  existingBrandMention Boolean @default(false)

  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, externalId])
  @@index([siteId, status])
  @@index([siteId, platform, status])
  @@index([discoveryRunId])
}

model Comment {
  id            String        @id @default(cuid())
  opportunity   Opportunity   @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId String
  site          Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId        String
  status        CommentStatus @default(DRAFT)

  // Content
  text         String   @db.Text
  persona      String
  qualityScore Float
  scoreReasons String[]

  // Posting
  providerId   String?
  orderId      String?
  postedAt     DateTime?
  errorMessage String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([opportunityId])
  @@index([siteId, status])
}

// ─── HV (High Value) Discovery Pipeline ──────────────────────

enum HVQueryCategory {
  COMPARISON
  RECOMMENDATION
  REVIEW
  HOW_TO
  PROBLEM_SOLVING
}

enum HVOpportunityStatus {
  DISCOVERED
  GENERATING
  PENDING_REVIEW
  APPROVED
  POSTING
  POSTED
  SKIPPED
  FAILED
}

enum HVCommentStatus {
  DRAFT
  APPROVED
  POSTED
  FAILED
  SKIPPED
}

model HVDiscoveryRun {
  id                    String             @id @default(cuid())
  site                  Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId                String
  status                DiscoveryRunStatus
  queriesUsed           String[]
  citationsFound        Int                @default(0)
  opportunitiesCreated  Int                @default(0)
  errorMessage          String?            @db.Text
  startedAt             DateTime           @default(now())
  completedAt           DateTime?

  hvOpportunities HVOpportunity[]

  @@index([siteId])
  @@index([siteId, status])
}

model HVQuery {
  id       String          @id @default(cuid())
  site     Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId   String
  query    String          @db.Text
  category HVQueryCategory

  responses HVQueryResponse[]

  createdAt DateTime @default(now())

  @@unique([siteId, query])
  @@index([siteId])
}

model HVQueryResponse {
  id           String @id @default(cuid())
  query        HVQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  queryId      String
  model        String
  responseText String  @db.Text
  tokensUsed   Int     @default(0)

  citations HVCitation[]

  createdAt DateTime @default(now())

  @@unique([queryId, model])
  @@index([queryId])
}

model HVCitation {
  id         String           @id @default(cuid())
  response   HVQueryResponse  @relation(fields: [responseId], references: [id], onDelete: Cascade)
  responseId String
  url        String
  domain     String
  title      String?
  snippet    String?          @db.Text
  platform   Platform?

  createdAt DateTime @default(now())

  @@index([responseId])
  @@index([url])
}

model HVOpportunity {
  id               String              @id @default(cuid())
  site             Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId           String
  discoveryRun     HVDiscoveryRun      @relation(fields: [discoveryRunId], references: [id], onDelete: Cascade)
  discoveryRunId   String
  platform         Platform
  status           HVOpportunityStatus @default(DISCOVERED)

  // Content
  externalId     String
  contentUrl     String
  title          String
  body           String?  @db.Text
  sourceContext  String
  author         String?
  viewCount      Int?
  commentCount   Int?
  publishedAt    DateTime?
  metadata       Json?

  // Citation-specific
  citationCount  Int      @default(0)
  citingModels   String[]
  citingQueries  String[]
  citationScore  Float    @default(0)

  // Validation
  isLocked    Boolean   @default(false)
  isArchived  Boolean   @default(false)
  threadAge   Int?
  validatedAt DateTime?

  hvComments HVComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, externalId])
  @@index([siteId, status])
  @@index([siteId, platform, status])
  @@index([discoveryRunId])
}

model HVComment {
  id              String          @id @default(cuid())
  hvOpportunity   HVOpportunity   @relation(fields: [hvOpportunityId], references: [id], onDelete: Cascade)
  hvOpportunityId String
  site            Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId          String
  status          HVCommentStatus @default(DRAFT)

  // Content
  text         String   @db.Text
  persona      String
  qualityScore Float
  scoreReasons String[]

  // Posting
  providerId   String?
  orderId      String?
  postedAt     DateTime?
  errorMessage String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hvOpportunityId])
  @@index([siteId, status])
}
